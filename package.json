{
  "name": "@cosineai/claw",
  "private": true,
  "version": "0.1.0",
  "description": "Cosine first-party OpenClaw extensions monorepo",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "release:inference": "node scripts/release-inference.mjs",
    "release:inference:dry-run": "node scripts/release-inference.mjs --dry-run",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck"
  }
}
