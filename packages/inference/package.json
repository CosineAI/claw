{
  "name": "@cosineai/claw-inference",
  "version": "0.1.0",
  "description": "Cosine inference provider plugin for OpenClaw",
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosineai/claw.git",
    "directory": "packages/inference"
  },
  "homepage": "https://github.com/cosineai/claw/tree/main/packages/inference",
  "bugs": {
    "url": "https://github.com/cosineai/claw/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "openclaw": "^2026.4.9",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.9"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "cosine"
    ],
    "install": {
      "npmSpec": "@cosineai/claw-inference",
      "minHostVersion": ">=2026.4.9"
    },
    "compat": {
      "pluginApi": ">=2026.4.9",
      "minGatewayVersion": ">=2026.4.9"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
